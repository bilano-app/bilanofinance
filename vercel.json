{
  "version": 2,
  "builds": [
    {
      "src": "server/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=1, stale-while-revalidate" },
        { "key": "Connection", "value": "keep-alive" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/reminder",
      "schedule": "0 13 * * *"
    }
  ]
}